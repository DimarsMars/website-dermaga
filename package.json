{
  "name": "dock-prebooking-monitoring",
  "version": "1.0.0",
  "description": "Dock Pre-Booking Monitoring System - Dermaga Timur, Pelabuhan Benoa",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build:client",
    "build:client": "npm run build --prefix client",
    "start": "cross-env NODE_ENV=production npm run start --prefix server",
    "start:server": "npm run start --prefix server",
    "db:migrate": "npm run db:migrate --prefix server",
    "db:seed": "npm run db:seed --prefix server",
    "db:fresh": "npm run db:fresh --prefix server",
    "install:all": "npm install && npm install --prefix server && npm install --prefix client",
    "test": "npm run test --prefix server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3"
  }
}
