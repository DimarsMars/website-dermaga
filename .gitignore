# =============================================================================
# Node.js / JavaScript Monorepo .gitignore
# Stack: Express + Socket.io + Jest (server) | Vite + Tailwind (client) | PostgreSQL
# =============================================================================

# ---------------------------------------------------------------------------
# Dependencies (node_modules)
# ---------------------------------------------------------------------------
node_modules/
**/node_modules/
jspm_packages/

# ---------------------------------------------------------------------------
# Build output & artifacts
# ---------------------------------------------------------------------------
# Client (Vite)
client/dist/
client/.vite/
dist/
build/

# Server
server/dist/
server/build/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Environment variables (JANGAN PERNAH di-commit)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
**/.env
**/.env.*
!**/.env.example
!**/.env.sample

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# Runtime, cache & process files
# ---------------------------------------------------------------------------
pids/
*.pid
*.pid.lock
*.seed
*.pid.lock
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tgz

# ---------------------------------------------------------------------------
# Test coverage & reports
# ---------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/
server/coverage/
client/coverage/

# Jest cache
.jest-cache/

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ---------------------------------------------------------------------------
# Operating System
# ---------------------------------------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Linux
*~
.directory
.Trash-*

# ---------------------------------------------------------------------------
# AI / dev assistant config (opsional - sesuaikan kebutuhan tim)
# ---------------------------------------------------------------------------
.kiro/
.claude/
.opencode/

# ---------------------------------------------------------------------------
# Database & uploads (file-based)
# ---------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
uploads/
server/uploads/

# ---------------------------------------------------------------------------
# Secret / credential files
# ---------------------------------------------------------------------------
*.pem
*.key
*.cert
*.p12
secrets/

# ---------------------------------------------------------------------------
# PM2 / production process manager
# ---------------------------------------------------------------------------
pmb2_logs/
ecosystem.config.*.local.js

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
.env.production
.env.staging
.tmp/
tmp/